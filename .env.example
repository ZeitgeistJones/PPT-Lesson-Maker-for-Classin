# Local dev only (used by server.js via dotenv).
# On Vercel, set these in Project Settings -> Environment Variables instead —
# this file is never uploaded there.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional comma-separated fallbacks used when the primary model is capacity-throttled:
# GEMINI_FALLBACK_MODELS=gemini-3.5-flash-lite,gemini-3.5-flash
